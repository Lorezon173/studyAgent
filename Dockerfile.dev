FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy

WORKDIR /workspace

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --dev

COPY . .

EXPOSE 1900

CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "1900", "--reload"]
